    "bcryptjs": "^3.0.2",
    "prisma": "^6.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  }
}
