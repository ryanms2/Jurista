# ============================================
# Jurista - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores

# -------- Database (PostgreSQL) --------
DATABASE_URL="postgresql://your-db:sua_senha_aqui@localhost:5432/your-db"
DB_PASSWORD="sua_senha_aqui"

# -------- MinIO (Object Storage) --------
MINIO_ENDPOINT="http://localhost:9000"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="jurista_minio"
MINIO_SECRET_KEY="sua_senha_minio_aqui"
MINIO_BUCKET_PHOTOS="client-photos"

# -------- NextAuth (Auth.js v5) --------
AUTH_SECRET="gerar_com_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# -------- App Config --------
NODE_ENV="development"
